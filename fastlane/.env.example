# Copy this file to fastlane/.env (git-ignored) and fill in your own values.
# These are account-specific identifiers kept out of the public repo.

# App Store Connect API key (the .p8 itself lives in
# ~/.appstoreconnect/private_keys/AuthKey_<ASC_KEY_ID>.p8 and is never committed)
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Apple Developer account
ASC_APPLE_ID=you@example.com
ASC_TEAM_ID=XXXXXXXXXX
